# Local-runner Snakefile for batch datacube creation.
# Spec: specs/08-workflows.md
#
# One job per input.csv row, each shelling out to the runner-agnostic task:
#     python -m fsd.workflows.task ...
# start.txt / done.txt sentinels give resumability (Snakemake skips rows whose
# done.txt exists); a small deterministic jitter staggers parallel job starts.
# Located at runtime via importlib.resources (see runners._snakefile_path).

import os
import sys
import time
from zlib import adler32

import pandas as pd

from fsd.storage import fs as _fs


def jitter(key, span=10):   # deterministic 0..(span-1)s delay
    return adler32(str(key).encode()) % max(int(span), 1)


def touch(filepath):
    os.makedirs(os.path.dirname(filepath), exist_ok=True)
    with open(filepath, "w") as h:
        h.write(pd.Timestamp.now(tz="UTC").isoformat())


input_df = pd.read_csv(config["input_csv"])
njobs = int(config.get("njobs", 1))
njobs_load_images = int(config.get("njobs_load_images", 1))
jitter_span = int(config.get("jitter_span", 1))

START_OUTFILENAME = "start.txt"
FINAL_OUTFILENAME = "done.txt"

row_by_done = {}
final_outputs = []
for _, row in input_df.iterrows():
    export_folderpath = row["export_folderpath"]
    if not _fs.is_local(export_folderpath):
        # The local Snakemake runner's own start.txt/done.txt sentinels (touch(),
        # below) are plain os.makedirs/open calls, not routed through fsd.storage —
        # on a remote export_folderpath they would silently create a garbage local
        # directory (literally named e.g. "abfss:", "data@acct.dfs.core.windows.net",
        # ...) instead of a real sentinel, breaking resumability without raising
        # (specs/31 §6 finding, 2026-07-17). Fail loud instead: the per-cube artifact
        # itself (datacube.npy etc, written by `fsd.workflows.task` via fs.save_npy)
        # is fully storage-seam-safe on blob — only Snakemake's OWN bookkeeping is
        # local-only today. Keep `run_folderpath` local (the default is
        # `<export_folderpath>/run`, so pass `run_folderpath=` explicitly to
        # `create_training_data` when `export_folderpath` is remote), or invoke
        # `python -m fsd.workflows.task` directly (TODO: a P2+ remote-sentinel design).
        raise RuntimeError(
            f"the local Snakemake runner's sentinel files must live on a local "
            f"filesystem; got a remote export_folderpath: {export_folderpath!r}. "
            "Pass a local run_folderpath to create_training_data (the datacube "
            "artifact writes are storage-seam-safe on blob regardless), or invoke "
            "`python -m fsd.workflows.task` directly for a single remote build."
        )
    # os.path.abspath is only meaningful (and safe) for a local path — setup()
    # already applied it; re-applying here is idempotent (the raise above rules
    # out the one case where it would be unsafe).
    export_folderpath = os.path.abspath(export_folderpath)
    done_output = os.path.join(export_folderpath, FINAL_OUTFILENAME)
    row_by_done[done_output] = {
        "start_output": os.path.join(export_folderpath, START_OUTFILENAME),
        "shapefilepath": row["shapefilepath"],
        "catalog_filepath": row["catalog_filepath"],
        "startdate": row["startdate"],
        "enddate": row["enddate"],
        "export_folderpath": export_folderpath,
        "mosaic_days": row["mosaic_days"],
        "mosaic_scheme": row["mosaic_scheme"],
        "scl_mask_classes": row["scl_mask_classes"],
        "bands": row["bands"],
    }
    final_outputs.append(done_output)


rule all:
    input:
        expand("{final_output}", final_output=final_outputs)


rule run:
    output:
        _done = "{final_output}"
    params:
        _r = lambda wc: row_by_done[wc.final_output],
        _python = sys.executable,
        _njobs = njobs,
        _njobs_load_images = njobs_load_images,
    threads: 1
    run:
        time.sleep(jitter(key=output._done, span=jitter_span))
        touch(params._r["start_output"])
        shell(
            "{params._python} -m fsd.workflows.task "
            "{params._r[shapefilepath]} "
            "{params._r[catalog_filepath]} "
            "\"{params._r[startdate]}\" "
            "\"{params._r[enddate]}\" "
            "{params._r[export_folderpath]} "
            "--bands {params._r[bands]} "
            "--mosaic-days {params._r[mosaic_days]} "
            "--mosaic-scheme {params._r[mosaic_scheme]} "
            "--scl-mask-classes {params._r[scl_mask_classes]} "
            "--njobs {params._njobs} "
            "--njobs-load-images {params._njobs_load_images}"
        )
        touch(output._done)
