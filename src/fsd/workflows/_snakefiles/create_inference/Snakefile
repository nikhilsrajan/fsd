# Local-runner Snakefile for per-cell ROI inference.
# Spec: specs/21-roi-inference-verb.md
#
# One job per input.csv row, each shelling out to the runner-agnostic per-cell task:
#     python -m fsd.workflows.infer_task ...   (build the cell's datacube + infer -> output.tif)
# This is the SAME build+infer unit an Azure Batch node dispatches at P4 (the runner seam).
# done_infer.txt sentinels give resumability (Snakemake skips cells already inferred); a small
# deterministic jitter staggers parallel job starts. Located at runtime via importlib.resources.

import os
import sys
import time
from zlib import adler32

import pandas as pd


def jitter(key, span=10):   # deterministic 0..(span-1)s delay
    return adler32(str(key).encode()) % max(int(span), 1)


def touch(filepath):
    os.makedirs(os.path.dirname(filepath), exist_ok=True)
    with open(filepath, "w") as h:
        h.write(pd.Timestamp.now(tz="UTC").isoformat())


input_df = pd.read_csv(config["input_csv"])
bundle_path = config["bundle_path"]
predict_batch_size = config.get("predict_batch_size", "")
skip_nan = int(config.get("skip_nan", 1))
njobs = int(config.get("njobs", 1))
njobs_load_images = int(config.get("njobs_load_images", 1))
jitter_span = int(config.get("jitter_span", 1))

START_OUTFILENAME = "start.txt"
FINAL_OUTFILENAME = "done_infer.txt"

row_by_done = {}
final_outputs = []
for _, row in input_df.iterrows():
    export_folderpath = os.path.abspath(row["export_folderpath"])
    done_output = os.path.join(export_folderpath, FINAL_OUTFILENAME)
    row_by_done[done_output] = {
        "start_output": os.path.join(export_folderpath, START_OUTFILENAME),
        "shapefilepath": row["shapefilepath"],
        "catalog_filepath": row["catalog_filepath"],
        "startdate": row["startdate"],
        "enddate": row["enddate"],
        "export_folderpath": export_folderpath,
        "output_filepath": os.path.join(export_folderpath, "output.tif"),
        "mosaic_days": row["mosaic_days"],
        "mosaic_scheme": row["mosaic_scheme"],
        "scl_mask_classes": row["scl_mask_classes"],
        "bands": row["bands"],
    }
    final_outputs.append(done_output)


rule all:
    input:
        expand("{final_output}", final_output=final_outputs)


rule run:
    output:
        _done = "{final_output}"
    params:
        _r = lambda wc: row_by_done[wc.final_output],
        _python = sys.executable,
        _bundle = bundle_path,
        _pbs = predict_batch_size,
        _skip = skip_nan,
        _njobs = njobs,
        _njobs_load_images = njobs_load_images,
    threads: 1
    run:
        r = params._r
        time.sleep(jitter(key=output._done, span=jitter_span))
        touch(r["start_output"])
        pbs = f'--predict-batch-size {params._pbs} ' if str(params._pbs) not in ("", "None") else ""
        skip = "" if int(params._skip) else "--no-skip-nan "
        cmd = (
            f'{params._python} -m fsd.workflows.infer_task '
            f'{r["shapefilepath"]} {r["catalog_filepath"]} '
            f'"{r["startdate"]}" "{r["enddate"]}" {r["export_folderpath"]} '
            f'--bands {r["bands"]} --mosaic-days {r["mosaic_days"]} '
            f'--mosaic-scheme {r["mosaic_scheme"]} '
            f'--scl-mask-classes {r["scl_mask_classes"]} '
            f'--njobs {params._njobs} --njobs-load-images {params._njobs_load_images} '
            f'--bundle {params._bundle} --output {r["output_filepath"]} '
            f'{pbs}{skip}'
        )
        shell(cmd)
        touch(output._done)
