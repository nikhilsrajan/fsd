# Local-runner Snakefile for infer-only fan-out over PRE-BUILT datacubes.
# Spec: specs/22-unify-inference-runner.md
#
# Replaces engine.run_local's retired mp.Pool. One job per group of `cubes_per_task` rows;
# each shells the runner-agnostic infer-only task:
#     python -m fsd.workflows.infer_only_task --input-csv <csv> --rows i:j --bundle ...
# **No mp.Pool** — parallelism across jobs is Snakemake (--cores); each job loops sequentially
# over its group with the bundle loaded once. A per-group `.done` sentinel gives resumability;
# the task itself also skips existing outputs, so a rerun never re-infers. Batch (P4) dispatches
# the same task. Located at runtime via importlib.resources.

import os
import sys

import pandas as pd

input_csv = config["input_csv"]
bundle_path = config["bundle_path"]
cubes_per_task = max(int(config.get("cubes_per_task", 1)), 1)
predict_batch_size = config.get("predict_batch_size", "")
skip_nan = int(config.get("skip_nan", 1))
overwrite = int(config.get("overwrite", 0))

input_df = pd.read_csv(input_csv)
n = len(input_df)
groups_dir = os.path.join(os.path.dirname(os.path.abspath(input_csv)), "groups")

group_by_sentinel = {}
sentinels = []
for lo in range(0, n, cubes_per_task):
    hi = min(lo + cubes_per_task, n)
    sentinel = os.path.join(groups_dir, f"group_{lo}_{hi}.done")
    group_by_sentinel[sentinel] = (lo, hi)
    sentinels.append(sentinel)


def touch(filepath):
    os.makedirs(os.path.dirname(filepath), exist_ok=True)
    with open(filepath, "w") as h:
        h.write(pd.Timestamp.now(tz="UTC").isoformat())


rule all:
    input:
        sentinels


rule run:
    output:
        _sentinel = "{sentinel}"
    params:
        _g = lambda wc: group_by_sentinel[wc.sentinel],
        _python = sys.executable,
        _csv = input_csv,
        _bundle = bundle_path,
        _pbs = predict_batch_size,
        _skip = skip_nan,
        _ow = overwrite,
    threads: 1
    run:
        lo, hi = params._g
        pbs = f'--predict-batch-size {params._pbs} ' if str(params._pbs) not in ("", "None") else ""
        skip = "" if int(params._skip) else "--no-skip-nan "
        ow = "--overwrite " if int(params._ow) else ""
        cmd = (
            f'{params._python} -m fsd.workflows.infer_only_task '
            f'--input-csv {params._csv} --rows {lo}:{hi} --bundle {params._bundle} '
            f'{pbs}{skip}{ow}'
        )
        shell(cmd)
        touch(output._sentinel)
