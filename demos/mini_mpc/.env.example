# Copy to .env and adjust if needed. Both vars are optional (compose falls back to the defaults
# baked into docker-compose.yml).

# Bind Docker's published ports to this host IP (127.0.0.1 = local-only).
MY_DOCKER_IP=127.0.0.1

# Host folder holding the inference-output COGs (bind-mounted read-only into the raster
# container at /data). MUST be the exact folder you pass to `load_pgstac.py --outputs-dir` —
# the href rewrite (spec 30 A2) assumes the two agree.
FSD_OUTPUTS_DIR=../../tests/outputs/demo_e2e/model_outputs/cells
